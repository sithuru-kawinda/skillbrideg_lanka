{
  "info": {
    "name": "SkillBridge Lanka API",
    "description": "Four independent Spring Boot microservices, no API gateway. See API.md at the project root for full documentation. All URLs and sample values below are hardcoded — no collection variables. For 'Create Job', log in first, copy the token from that response, and paste it into the Authorization header value (replacing PASTE_TOKEN_HERE). Every success response now includes a 'message' field (e.g. {\"message\": \"Login successful\", \"token\": \"...\"}) so you can see at a glance in Postman that the call worked; error responses are unchanged and still vary in shape by service (see API.md).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication-Service (:8082)",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/api/auth/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["api", "auth", "health"]
            }
          }
        },
        {
          "name": "Test",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8082/api/auth/test",

    {
      "name": "Job-Service (:8083)",
      "item": [
        {
          "name": "Create Job (requires RECRUITER token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer PASTE_TOKEN_HERE" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobName\": \"Software Engineer\",\n  \"jobDescription\": \"Build and maintain backend services.\",\n  \"jobStatus\": \"OPEN\",\n  \"level\": \"JUNIOR\",\n  \"durationinmonths\": 12,\n  \"salary\": 150000,\n  \"recruiterID\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:8083/job/create",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["job", "create"]
            }
          },
          "response": []
        },
        {
          "name": "Get Jobs By Level",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/job/JUNIOR",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["job", "JUNIOR"]
            }
          }
        },
        {
          "name": "Get Jobs (filtered by names/levels)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/job/byall?jobnames=Software Engineer&levels=JUNIOR",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["job", "byall"],
              "query": [
                { "key": "jobnames", "value": "Software Engineer" },
                { "key": "levels", "value": "JUNIOR" }
              ]
            }
          }
        },
        {
          "name": "Get All Jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/job/all",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["job", "all"]
            }
          }
        },
        {
          "name": "Get Job With Recruiter",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8083/job/withRecruiter/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["job", "withRecruiter", "1"]
            }
          }
        }
      ]
    },
